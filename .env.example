# Node AI Life Manager — Frontend Environment Variables
# Copy to .env.local and fill in your values after running `sam deploy`

# API Gateway (HTTP API) URL — from SAM deploy Outputs.ApiUrl
VITE_API_URL=https://xxxxxxxxxx.execute-api.ap-northeast-2.amazonaws.com/dev

# Cognito — from SAM deploy Outputs.UserPoolId / UserPoolClientId
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Region
VITE_AWS_REGION=ap-northeast-2
